# Oracle Database Credentials — EXAMPLE FILE
# ─────────────────────────────────────────────────────────
# 1. Copy this file to   .env
# 2. Fill in your actual Oracle connection details
# 3. Never commit .env to git (it's already in .gitignore)
# ─────────────────────────────────────────────────────────

ORA_USER=your_oracle_username
ORA_PASS=your_oracle_password
ORA_HOST=your_oracle_host_or_ip
ORA_PORT=1521
ORA_SID=ORCLCDB

# Cloudflare Tunnel token
# Get it from: dash.cloudflare.com > Zero Trust > Networks > Tunnels > Create a tunnel
CLOUDFLARE_TOKEN=your_cloudflare_tunnel_token_here
